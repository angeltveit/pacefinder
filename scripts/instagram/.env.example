# Instagram Graph API scraper – environment variables
# Copy this file to .env and fill in your values.

# -----------------------------------------------------------------------
# Required
# -----------------------------------------------------------------------

# Long-lived User Access Token or Page Access Token from Meta.
# Obtain from Meta Developer Dashboard → your app → Instagram → Generate Token.
# Must have the following permissions:
#   instagram_basic, instagram_manage_insights (read-only is fine)
#   or for business accounts: pages_read_engagement + instagram_basic
INSTAGRAM_ACCESS_TOKEN=

# -----------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------

# Instagram User ID (numeric string, e.g. "17841400455970028").
# If omitted the scraper calls /me to discover it automatically from the token.
INSTAGRAM_ACCOUNT_ID=

# Maximum number of posts to fetch (1–200, default 25).
INSTAGRAM_MAX_POSTS=25

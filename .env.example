# PostgreSQL connection string
# Local dev: no credentials needed if using peer/trust auth (default on most Linux installs)
DB_CONNECTION=postgresql://localhost:5432/race_lookup

# Redis (optional — stats degrade gracefully without it)
REDIS_URL=redis://localhost:6379

# better-auth
BETTER_AUTH_SECRET=dev-only-secret-replace-in-production-32c
ORIGIN=http://localhost:5173

# Agent trigger secret (used by cron to call POST /api/agent/run)
AGENT_SECRET=dev-agent-secret

# Monthly LLM spend cap in USD — agent is blocked when exceeded (extendable in admin UI)
MONTHLY_LLM_BUDGET_USD=10

# LLM provider: openai | anthropic | compatible
LLM_PROVIDER=openai
LLM_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini
# Optional: override base URL for OpenAI-compatible endpoints
# LLM_BASE_URL=https://api.openai.com/v1

# Tavily search API (https://tavily.com)
TAVILY_API_KEY=

# Google Custom Search (optional)
GOOGLE_CSE_ID=
GOOGLE_CSE_API_KEY=

# Apify (optional — for social media monitoring)
APIFY_API_KEY=
